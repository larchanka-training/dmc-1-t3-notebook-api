PROJECT_NAME="Backend API"
VERSION="1.0.0"
ENVIRONMENT="development"
LOG_LEVEL="DEBUG"
API_V1_STR="/api/v1"
DATABASE_URL="postgresql+psycopg://admin:admin123@postgres:5432/wiki"
BACKEND_CORS_ORIGINS="http://localhost:3000,http://127.0.0.1:3000,http://localhost:8080,https://localhost:8443,http://notebook.com:8080,https://notebook.com:8443"
AUTH_OTP_TTL_SECONDS=300
AUTH_OTP_MAX_ATTEMPTS=5
AUTH_OTP_REQUEST_COOLDOWN_SECONDS=60
AUTH_OTP_CODE_LENGTH=6
AUTH_OTP_HASH_SECRET="development-auth-otp-secret"
AUTH_RETURN_DEV_OTP=true
AUTH_DEBUG_MODE=false
AUTH_SESSION_TTL_SECONDS=2592000
AUTH_SESSION_COOKIE_NAME="notebook_session"
AUTH_SESSION_COOKIE_SECURE=true
AUTH_SESSION_COOKIE_SAMESITE="lax"
AUTH_SESSION_COOKIE_PATH="/"
AUTH_SESSION_HASH_SECRET="development-auth-session-secret"

GOOGLE_OAUTH_CLIENT_ID=your_google_oauth_client_id
GOOGLE_OAUTH_CLIENT_SECRET=GOCSPX-your_google_oauth_client_secret
GOOGLE_OAUTH_REDIRECT_URI=https://api.notebook.com:8443/api/v1/auth/google/callback
GOOGLE_OAUTH_SUCCESS_REDIRECT_URL=https://notebook.com:8443/
GOOGLE_OAUTH_ERROR_REDIRECT_URL=https://notebook.com:8443/auth/error
